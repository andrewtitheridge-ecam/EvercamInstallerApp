{
  "name": "Evercam Installer Snapshot Tool",
  "short_name": "Installer",
  "description": "Find Evercam job, project, and camera snapshots onsite.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
